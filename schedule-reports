import os
import smtplib
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart
import google.generativeai as genai

# 1. Configuração das APIs
# IMPORTANTE: No GitHub Actions, você deve manter o os.getenv e configurar no repositório.
# Se você for rodar localmente ou no Colab APENAS PARA TESTE, pode usar a string:
GEMINI_API_KEY = "AIzaSyCt9QUJ6J6r6Au7WRRWDHSBHCxDXW8sUwI" 
EMAIL_USER = os.getenv("EMAIL_USER")
EMAIL_PASS = os.getenv("EMAIL_PASS") # Senha de App do Gmail
EMAIL_RECEIVER = os.getenv("EMAIL_RECEIVER")

genai.configure(api_key=GEMINI_API_KEY)

def run_agent():
    # 2. Configura o modelo com Google Search
    model = genai.GenerativeModel(
        model_name='gemini-1.5-flash',
        tools=[{'google_search_retrieval': {}}]
    )

    prompt = """
    Você é um Analista Sênior de Propriedade Intelectual. 
    Pesquise notícias das últimas 24 horas sobre 'Direitos Autorais e IA' nos idiomas Inglês, Português e Espanhol.
    
    Regras de Negócio:
    - Escopo: Global (ênfase em EUA, União Europeia, Brasil e Ásia).
    - Conteúdo: Apenas decisões judiciais, PLs, regulamentações e acordos oficiais. 
    - Formatação: Organize por Continente > País. Use Markdown para o corpo do e-mail.
    - Cada item deve ter: Título em PT-BR, Resumo (3 frases) e Link da Fonte.
    
    Se não houver nada relevante no dia, responda apenas: 'Sem atualizações críticas hoje.'
    """

    response = model.generate_content(prompt)
    return response.text

def send_email(content):
    if "Sem atualizações críticas" in content:
        print("Nada relevante hoje. E-mail não enviado.")
        return

    msg = MIMEMultipart()
    msg['From'] = EMAIL_USER
    msg['To'] = EMAIL_RECEIVER
    msg['Subject'] = "Relatório Diário: Direitos Autorais & IA"

    # Usando 'html' no lugar de 'plain' se quiser que os links fiquem clicáveis 
    # e a formatação Markdown seja respeitada por alguns leitores de e-mail.
    msg.attach(MIMEText(content, 'plain'))

    try:
        server = smtplib.SMTP('smtp.gmail.com', 587)
        server.starttls()
        server.login(EMAIL_USER, EMAIL_PASS)
        server.send_message(msg)
        server.quit()
        print("E-mail enviado com sucesso!")
    except Exception as e:
        print(f"Erro ao enviar e-mail: {e}")

if __name__ == "__main__":
    report = run_agent()
    send_email(report)
